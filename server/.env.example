DATABASE_URL="mysql://root:password@localhost:3306/zunuz_db"
JWT_SECRET="change-me"
JWT_ADMIN_SECRET="change-me"
PORT=3001
# Comma-separated list of allowed frontend origins (custom domain(s) + the raw *.vercel.app URL)
CLIENT_URL="http://localhost:5173"

# OAuth 2.0 Client ID from Google Cloud Console (same value as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# SMTP Mail Server Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Zunuz <your-email@gmail.com>"

